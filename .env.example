# Session Service configuration
ENV=dev
LOG_LEVEL=debug
AWS_REGION=us-east-1
AWS_ENDPOINT_URL=http://localhost:8000
DYNAMODB_TABLE_PREFIX=dev-
POLICY_SERVICE_URL=http://localhost:8001
WORKSPACE_SERVICE_URL=http://localhost:8002
DOWNSTREAM_TIMEOUT=30.0
MIN_DESKTOP_APP_VERSION=0.1.0
MIN_AGENT_HOST_VERSION=0.1.0
SESSION_EXPIRY_HOURS=24

# Sandbox launcher configuration
SANDBOX_LAUNCHER_TYPE=local  # "ecs" or "local"
SANDBOX_MAX_CONCURRENT_SESSIONS=5
SESSION_SERVICE_URL=http://localhost:8000

# ECS launcher (production)
ECS_CLUSTER=cowork-dev
ECS_TASK_DEFINITION=cowork-dev-agent-runtime
ECS_SUBNETS=[]
ECS_SECURITY_GROUPS=[]
SANDBOX_IMAGE=

# Local launcher (development)
AGENT_RUNTIME_PATH=../cowork-agent-runtime

# Sandbox lifecycle (idle timeout, provisioning timeout, max duration)
SANDBOX_IDLE_TIMEOUT_SECONDS=1800
SANDBOX_MAX_DURATION_SECONDS=14400
SANDBOX_PROVISION_TIMEOUT_SECONDS=180
SANDBOX_LIFECYCLE_CHECK_INTERVAL_SECONDS=300

# Proxy settings
PROXY_ENDPOINT_CACHE_TTL_SECONDS=30
PROXY_ACTIVITY_BATCH_SECONDS=60
PROXY_TIMEOUT_SECONDS=30.0
PROXY_SSE_TIMEOUT_SECONDS=14400.0

# Upload settings
UPLOAD_SYNC_TIMEOUT_SECONDS=10.0
